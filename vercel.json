{
  "crons": [
    {
      "path": "/api/sync-fixtures",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/sync-highlights",
      "schedule": "0 2 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*SERankingBacklinksBot.*"
        }
      ],
      "mitigate": {
        "action": "deny"
      }
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": ".*\\.vercel\\.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
